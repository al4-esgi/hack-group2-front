{
  "expo": {
    "name": "Guide Michelin",
    "slug": "guide-michelin",
    "scheme": "com.guidemichelin.front",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/icons/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./public/icons/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guidemichelin.front"
    },
    "android": {
      "package": "com.guidemichelin.front",
      "adaptiveIcon": {
        "foregroundImage": "./public/icons/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "eas": {
        "projectId": "8f376b54-caa7-490c-b902-243774d3b42e"
      }
    },
    "owner": "cmbhugos-organization",
    "plugins": [
      "expo-web-browser",
      "expo-font",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby restaurants and hotels."
        }
      ],
      "expo-video"
    ]
  }
}
